# Use official Node.js image
FROM node:18-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm ci

# Copy backend source
COPY backend ./backend

# Build backend
RUN npm run build --workspace=backend

# Expose port
EXPOSE 5000

# Start backend
CMD ["npm", "start", "--workspace=backend"]
